{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 550,
  "height": 280,
  "title": {
    "text": "National Benchmark: Renewable Energy Penetration by State (2024)",
    "fontSize": 14,
    "anchor": "start",
    "color": "#004d4d",
    "subtitle": "Percentage of total electricity generated from renewable sources"
  },
  "data": {
    "url": "data/state_summary_2024.csv"
  },
  "mark": {
    "type": "bar", 
    "cornerRadiusEnd": 4
  },
  "encoding": {
    "x": {
      "field": "Renewable_Share_Percent",
      "type": "quantitative",
      "title": "Renewable Generation Share (%)",
      "scale": {"domain": [0, 100]}
    },
    "y": {
      "field": "State",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "title": null,
        "labelAngle": 0,
        "labelPadding": 10,
        "labelFontSize": 11
      }
    },
    "color": {
      "condition": {
        "test": "datum.State === 'Victoria'",
        "value": "#008080"
      },
      "value": "#ced4da"
    },
    "tooltip": [
      {"field": "State", "type": "nominal"},
      {"field": "Renewable_Share_Percent", "type": "quantitative", "title": "Renewable Share (%)", "format": ".1f"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "axis": {"grid": true, "gridColor": "#f1f3f5"}
  }
}