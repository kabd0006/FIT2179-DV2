{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 260,
  "data": {
    "url": "data/state_summary_2024.csv"
  },
  "mark": {
    "type": "bar", 
    "cornerRadiusEnd": 5,
    "height": {"band": 0.65}
  },
  "encoding": {
    "x": {
      "field": "Renewable_Share_Percent",
      "type": "quantitative",
      "title": "Renewable Generation Share (%)",
      "scale": {"domain": [0, 100]},
      "axis": {"grid": true, "gridColor": "#edf2f7", "tickCount": 5}
    },
    "y": {
      "field": "State",
      "type": "nominal",
      "sort": "-x",
      "axis": {
        "title": null,
        "labelPadding": 12,
        "labelFontSize": 12,
        "domain": false,
        "ticks": false
      }
    },
    "color": {
      "condition": {
        "test": "datum.State === 'Victoria'",
        "value": "#008080"
      },
      "value": "#cbd5e0"
    },
    "tooltip": [
      {"field": "State", "type": "nominal"},
      {"field": "Renewable_Share_Percent", "type": "quantitative", "title": "Renewable Share (%)", "format": ".1f"}
    ]
  },
  "config": {
    "view": {"stroke": null}
  }
}