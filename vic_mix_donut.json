{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 260,
  "title": {
    "text": "Victoria's Electricity Generation Profile (2023-24)",
    "fontSize": 14,
    "anchor": "start",
    "color": "#0b2c24"
  },
  "data": {
    "url": "data/vic_energy_timeline.csv"
  },
  "transform": [
    {
      "filter": "datum.Year === '2023-24'"
    },
    {
      "filter": "datum['Generation (GWh)'] > 0"
    }
  ],
  "mark": {
    "type": "arc",
    "innerRadius": 65,
    "outerRadius": 95,
    "stroke": "#ffffff",
    "strokeWidth": 2
  },
  "encoding": {
    "theta": {
      "field": "Generation (GWh)",
      "type": "quantitative"
    },
    "color": {
      "field": "Fuel Type",
      "type": "nominal",
      "title": "Fuel Stream",
      "scale": {
        "domain": ["Brown coal", "Natural gas", "Oil products", "Wind", "Hydro", "Large-scale solar PV", "Small-scale solar PV"],
        "range": ["#744210", "#dd6b20", "#718096", "#3182ce", "#2b6cb0", "#319795", "#d69e2e"]
      },
      "legend": {
        "orient": "right",
        "offset": 20,
        "rowPadding": 6
      }
    },
    "tooltip": [
      {"field": "Fuel Type", "type": "nominal", "title": "Source"},
      {"field": "Generation (GWh)", "type": "quantitative", "title": "Output (GWh)", "format": ",.0f"}
    ]
  },
  "config": {
    "view": {"stroke": null}
  }
}